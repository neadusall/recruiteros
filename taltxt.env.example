# =============================================================================
# OS Text (taltxt) — environment reference
# =============================================================================
# This is the env for the embedded SMS app (the money-maker-sms submodule),
# served on its own subdomain (taltxt.recruitersos.co) and shown in the portal
# under the "OS Text" route.
#
# On a server, deploy.sh scaffolds money-maker-sms/.env.production for you with
# the secrets + URLs already generated — you only fill in the API keys below.
# To create it by hand: copy this file to money-maker-sms/.env.production and
# fill it in. (That path is git-ignored; never commit real secrets.)
#
# After editing on the server:  docker compose up -d --build taltxt
# =============================================================================

# --- Public URL ---------------------------------------------------------------
# The subdomain Caddy serves taltxt on. Drives auth callbacks, QStash webhook
# targets, and the instant-access link.
AUTH_URL=https://taltxt.recruitersos.co
PUBLIC_APP_URL=https://taltxt.recruitersos.co
AUTH_TRUST_HOST=true
NODE_ENV=production

# --- Auth ---------------------------------------------------------------------
# AUTH_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# ACCESS_TOKEN: optional one-click instant-access link (/api/enter?token=...).
#   openssl rand -hex 24
ACCESS_TOKEN=
ACCESS_EMAIL=neadusall@gmail.com
# Comma-separated allow-list. Only these emails can sign in (magic link).
ALLOWED_EMAILS=neadusall@gmail.com

# --- Database (REQUIRED) ------------------------------------------------------
# Neon (neon.tech) connection string, include ?sslmode=require. The app cannot
# run without this — login and every page hit the DB.
DATABASE_URL=

# --- Email magic-link (Gmail SMTP recommended) --------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
# Gmail App Password (myaccount.google.com → Security → App passwords)
SMTP_PASS=
SMTP_FROM=

# --- Telnyx (SMS) -------------------------------------------------------------
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_FROM_NUMBER=
# ED25519 public key — verifies inbound webhooks (Account → API Keys).
TELNYX_PUBLIC_KEY=
# Messages-per-second, your registered 10DLC throughput.
TELNYX_MPS=1

# --- QStash (scheduled sends / drains) ----------------------------------------
QSTASH_TOKEN=
QSTASH_URL=https://qstash.upstash.io
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- AI -----------------------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Optional -----------------------------------------------------------------
APP_TIMEZONE=America/New_York
# Enrichment (RapidAPI LinkedIn), cost dashboard, batch size, etc. — see README.
# RAPIDAPI_KEY=
# RAPIDAPI_LINKEDIN_HOST=
# BATCH_SIZE=10
