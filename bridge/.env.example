# Outreach Bridge configuration (copy to bridge/.env or export before running)

# Port the bridge listens on
PORT=8787

# Token the BACKEND must send (set RECRUITEROS_OUTREACH_TOKEN to the same value).
OUTREACH_TOKEN=dev-outreach-token

# Token the EXTENSION agent must send (defaults to OUTREACH_TOKEN if unset).
AGENT_TOKEN=dev-outreach-token

# Where to forward accept/reply events so the sequence engine advances.
# Point this at the backend's LinkedIn webhook.
BACKEND_WEBHOOK_URL=http://localhost:3000/api/linkedin/webhook
# Optional HMAC secret; if set, sent as x-unipile-signature (matches UNIPILE_WEBHOOK_SECRET).
BACKEND_WEBHOOK_SECRET=
