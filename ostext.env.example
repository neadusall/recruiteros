# =============================================================================
# OS Text: environment reference
# =============================================================================
# This is the env for the embedded SMS app (the money-maker-sms submodule),
# served same-origin under /ostext-app on every portal domain and shown in
# the portal under the "OS Text" route.
#
# On a server, deploy.sh scaffolds money-maker-sms/.env.production for you with
# the secrets + URLs already generated — you only fill in the API keys below.
# To create it by hand: copy this file to money-maker-sms/.env.production and
# fill it in. (That path is git-ignored; never commit real secrets.)
#
# After editing on the server:  docker compose up -d --build taltxt
# =============================================================================

# --- Public URL ---------------------------------------------------------------
# OS Text is served same-origin on the portal domain under /ostext-app (Caddy
# proxies it there on every portal host). Drives auth callbacks, QStash webhook
# targets, and the instant-access link. The legacy taltxt subdomain still works
# for previously-configured webhooks (Caddy rewrites it onto /ostext-app).
AUTH_URL=https://recruitersos.co/ostext-app
PUBLIC_APP_URL=https://recruitersos.co/ostext-app
AUTH_TRUST_HOST=true
NODE_ENV=production

# --- Auth ---------------------------------------------------------------------
# AUTH_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# ACCESS_TOKEN: optional one-click instant-access link (/api/enter?token=...).
#   openssl rand -hex 24
ACCESS_TOKEN=
ACCESS_EMAIL=neadusall@gmail.com
# Comma-separated allow-list. Only these emails can sign in (magic link).
ALLOWED_EMAILS=neadusall@gmail.com

# --- Database (REQUIRED) ------------------------------------------------------
# The shared self-hosted Postgres (the `db` container), in its own `taltxt`
# database. Use the SAME password as POSTGRES_PASSWORD in .env.production.
# deploy.sh fills this in for you; run ./ostext-db-setup.sh once to create the
# database + push the schema. The app cannot run without this.
DATABASE_URL=postgres://recruiteros:<POSTGRES_PASSWORD>@db:5432/taltxt

# --- Email magic-link (Gmail SMTP recommended) --------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
# Gmail App Password (myaccount.google.com → Security → App passwords)
SMTP_PASS=
SMTP_FROM=

# --- Telnyx (SMS) -------------------------------------------------------------
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_FROM_NUMBER=
# ED25519 public key — verifies inbound webhooks (Account → API Keys).
TELNYX_PUBLIC_KEY=
# Messages-per-second, your registered 10DLC throughput.
TELNYX_MPS=1

# --- QStash (scheduled sends / drains) ----------------------------------------
QSTASH_TOKEN=
QSTASH_URL=https://qstash.upstash.io
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- AI -----------------------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Recruiter reply alerts ---------------------------------------------------
# When a candidate texts back, the campaign's recruiter gets an SMS on their
# cell immediately, then a reminder every OSTEXT_ALERT_NAG_MINUTES until they
# reply to that candidate from the inbox.
# Cell that gets EVERY alert regardless of campaign owner (defaults to Ryan's
# cell in code; set to "off" to disable).
# OSTEXT_ALERT_ALWAYS_CELL=+19153737987
# Per-recruiter cells, keyed by the campaign's recruiter email:
# OSTEXT_ALERT_CELLS=noah@lumesp.com=+15551230000,josh@lumesp.com=+15551231111
# OSTEXT_ALERT_NAG_MINUTES=30

# --- Optional -----------------------------------------------------------------
APP_TIMEZONE=America/New_York
# Enrichment (RapidAPI LinkedIn), cost dashboard, batch size, etc. — see README.
# RAPIDAPI_KEY=
# RAPIDAPI_LINKEDIN_HOST=
# BATCH_SIZE=10
