# Lume jobs backend — copy the values you want into the repo-root .env.production
# (the file docker-compose reads). All are optional; sensible defaults apply.

# Team login for the /portal admin (CHANGE THESE before going live):
LUME_JOBS_USER=lume
LUME_JOBS_PASS=change-this-password

# Random string used to sign session cookies. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LUME_JOBS_SECRET=

# Lead notifications: every application/inquiry is emailed here (comma-separated).
LUME_NOTIFY_EMAILS=josh@lumesp.com,ryan@lumesp.com
# Email is sent via Resend, REUSING the RESEND_API_KEY + EMAIL_FROM the main app
# already has in .env.production — no extra setup needed if those are set. The
# EMAIL_FROM sender domain must be verified in Resend (it already is for the app).
# Optional Web3Forms fallback if you don't use Resend:
LUME_WEB3FORMS_KEY=
