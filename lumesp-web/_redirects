# Cloudflare Pages redirects.
# Canonical host = www.lumesp.com (the domain stays on GoDaddy DNS, which can't
# CNAME a bare apex to Pages — so the apex 301-forwards to www at GoDaddy, and
# www is the only host Pages serves). No host redirect needed here.

# SMS opt-in page lives at /opt-in/. Keep the old /sms-opt-in/ path working for
# anyone who already has it (e.g. an in-flight 10DLC submission).
/sms-opt-in    /opt-in/   301
/sms-opt-in/*  /opt-in/   301
