# Automatic HTTPS for both apex and www. Caddy fetches and renews the
# Let's Encrypt certificate on its own once DNS points here.
recruitersos.co, www.recruitersos.co {
	encode zstd gzip
	reverse_proxy app:3000
}

# OS Text (taltxt) — the embedded SMS app on its own subdomain. The portal's
# "OS Text" panel iframes this. Caddy fetches/renews its Let's Encrypt cert
# automatically once taltxt.recruitersos.co's DNS A record points here.
taltxt.recruitersos.co {
	encode zstd gzip
	reverse_proxy taltxt:3000
}
