# Global options. On-demand TLS lets us obtain a certificate for any customer's
# white-label domain the moment it's first requested — but ONLY after our app
# confirms (via the `ask` endpoint) that the domain is a verified custom domain
# of a real workspace. Without that gate, on-demand TLS would be a cert-issuance
# DoS vector, so the catch-all block below depends on it.
{
	on_demand_tls {
		ask http://app:3000/api/caddyask
	}
}

# Automatic HTTPS for both apex and www. Caddy fetches and renews the
# Let's Encrypt certificate on its own once DNS points here.
recruitersos.co, www.recruitersos.co {
	encode zstd gzip
	reverse_proxy app:3000
}

# OS Text (taltxt) — the embedded SMS app on its own subdomain. The portal's
# "OS Text" panel iframes this. Caddy fetches/renews its Let's Encrypt cert
# automatically once taltxt.recruitersos.co's DNS A record points here.
taltxt.recruitersos.co {
	encode zstd gzip
	reverse_proxy taltxt:3000
}

# Lume Search Partners — static white-label MARKETING site, served from this same
# box (the keeper). Apex is canonical; www 301-redirects to it. These named blocks
# are more specific than the catch-all below, so they always win. The portal host
# app.lumesp.com has its own named block (below) — it must NOT be left to the
# catch-all, whose on-demand TLS is gated by /api/caddyask and would reject it
# ("unknown domain"), so no cert would ever issue. Automatic HTTPS issues once the
# A-record points here.
lumesp.com {
	encode zstd gzip
	# /api/* is the jobs + applications backend (login, post/delete jobs, apply).
	# Everything else is the static marketing site. The matcher is more specific,
	# so API traffic is proxied and all other paths fall through to file_server.
	@api path /api/*
	handle @api {
		reverse_proxy lume-jobs:3000
	}
	handle {
		root * /srv/lumesp
		file_server
	}
}

www.lumesp.com {
	redir https://lumesp.com{uri} permanent
}

# Lume app/portal host. seed-portal.html (served from lumesp.com) calls
# https://app.lumesp.com/api/seed-portal, and other Lume app APIs land here too.
# This MUST proxy to the RecruiterOS app (app:3000), where /api/seed-portal lives
# — NOT to lume-jobs:3000 (that service has no such route). It needs its own
# named block so Caddy issues a normal Let's Encrypt cert: the catch-all's
# on-demand TLS is denied for this host by /api/caddyask. DNS A-record for
# app.lumesp.com already points at this box.
app.lumesp.com {
	encode zstd gzip
	reverse_proxy app:3000
}

# RecruitersOS Mail — the ACS email infrastructure embedded in the portal
# (#setup/email). Reverse-proxies to the recruitersos-mail stack (separate compose
# project on the shared recruiteros_default network). Named blocks win over the
# catch-all below; Caddy issues Let's Encrypt certs automatically once DNS points here.
mail.recruitersos.co {
	encode zstd gzip
	reverse_proxy mail-web:3000
}
mailapi.recruitersos.co {
	encode zstd gzip
	reverse_proxy mail-api:4000
}

# Catch-all for white-label CUSTOM DOMAINS (e.g. app.acme.com). The explicit
# blocks above are more specific and always win, so house traffic never reaches
# here. Any other host gets an on-demand Let's Encrypt cert — gated by the
# `ask` endpoint above, which only says yes for verified workspace domains —
# and is proxied to the same app. Certs persist in the caddy_data volume.
https:// {
	tls {
		on_demand
	}
	encode zstd gzip
	reverse_proxy app:3000
}
