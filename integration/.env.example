# RecruitersOS · LinkedIn Engine, environment

# --- Outreach backend selection ---------------------------------------
# internal = run on your own LinkedIn outreach tools
# unipile  = integrate the Unipile API (default)
RECRUITEROS_OUTREACH_PROVIDER=unipile

# --- Unipile (third-party API path) -----------------------------------
# DSN defaults to api48.unipile.com:17846 in code; only the API key is required.
UNIPILE_DSN=api48.unipile.com:17846
UNIPILE_API_KEY=
UNIPILE_WEBHOOK_SECRET=

# --- Internal outreach service (internal path) ------------------------
RECRUITEROS_OUTREACH_URL=https://outreach.internal.recruitersos.co
RECRUITEROS_OUTREACH_TOKEN=

# --- Texting platform (the Money Maker) -------------------------------
# telnyx   = Telnyx Messaging API (reuses your built phone/SMS setup)
# internal = route texting through your own built SMS tool
RECRUITEROS_SMS_PROVIDER=telnyx
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
# E.164 sender / caller-ID number on your messaging profile (SMS + voice).
TELNYX_FROM_NUMBER=
# Internal SMS gateway (when RECRUITEROS_SMS_PROVIDER=internal)
RECRUITEROS_SMS_URL=https://sms.internal.recruitersos.co
RECRUITEROS_SMS_TOKEN=

# --- Voice dialer (Telnyx Call Control + Premium AMD) -----------------
# Telnyx Call Control application id the outbound dialer places calls on.
TELNYX_CONNECTION_ID=
# ED25519 public key (Portal > Webhooks) used to verify /api/voice/webhook.
# No-op until set, so the dialer runs end to end in dev without it.
TELNYX_PUBLIC_KEY=
# Recruiter number a detected HUMAN is warm-transferred to (E.164).
TELNYX_TRANSFER_NUMBER=
# Pre-recorded voicemail dropped when a MACHINE answers (publicly reachable URL).
TELNYX_VOICEMAIL_AUDIO_URL=
# Public base URL of this app; the dialer builds the per-call webhook from it.
RECRUITEROS_APP_URL=https://app.recruitersos.co

# --- Email-sent -> voice-drop trigger (RECRUITEROS-BACKEND.md §4-C) ----
# OFF by default: emailing a prospect does NOT cold-call them unless you opt in.
# When on, a successful email send enqueues the prospect into the voice campaign
# below; the voice cron (/api/voice/cron) then dials only within the lead's local
# window, capped + line-type-filtered. Set both to activate.
RECRUITEROS_VOICE_ON_SEND=
# Id of a LAUNCHED (consent-attested) voice campaign to enqueue reactive drops into.
RECRUITEROS_VOICE_ON_SEND_CAMPAIGN=

# --- Cold email (Instantly.ai — the email sending channel) ------------
# Powers the `email` channel: the 9:00 cadence pushes approved drafts to an
# Instantly campaign (lib/channels -> instantly.addLeads), which sends from your
# own warmed inboxes/domains and runs the drip. Without this key every email
# send is a dry-log no-op (so the engine runs end-to-end uncredentialed).
# Get it in Instantly: Settings -> Integrations -> API -> create an API key.
INSTANTLY_API_KEY=
# HMAC secret for the Instantly reply webhook. Point Instantly's "reply"/"lead
# replied" webhook at /api/response/webhook/instantly?ws=<workspaceId>; this
# secret authenticates it (x-instantly-signature). Blank = signature check is
# skipped (dev only). Set it in production.
INSTANTLY_WEBHOOK_SECRET=

# --- AI (personalization + reply classification) ----------------------
ANTHROPIC_API_KEY=
RECRUITEROS_LLM_MODEL=claude-sonnet-4-6

# --- API auth ---------------------------------------------------------
# Bearer token RecruitersOS backend uses to call the LinkedIn API routes
RECRUITEROS_API_TOKEN=
# Shared secret the scheduler sends to the cron route
RECRUITEROS_CRON_SECRET=

# --- Owner Console (private back office) -------------------------------
# The ONLY email(s) allowed into /owner-console.html and /api/owner/*.
# Comma-separate for more than one. Anyone else (even workspace admins) gets
# a 404. Leave unset only in dev; ALWAYS set this in production.
OWNER_EMAIL=neadusall@gmail.com
# Optional service key so background workers can POST cost events to
# /api/owner/usage/ingest without an owner session (Authorization: Bearer ...).
USAGE_INGEST_KEY=
# Private URL slug for the owner console. The console is served ONLY at
# /<slug>.html (no guessable /owner-console path exists). Leave blank to have a
# stable random slug generated into integration/.owner-console-slug on build;
# set this to pin/rotate your own. Treat it like a password.
OWNER_CONSOLE_SLUG=

# --- White-label credential isolation ---------------------------------
# Your OWN operating workspace id (the "house"). It alone uses the env API keys
# below (Telnyx, enrichment, etc.); every other (customer) workspace is isolated
# to its own portal-saved keys and cannot ride yours unless you grant it via
# /api/owner/grants. Find the id in the Owner Console -> Accounts.
#   - SET it to switch on strict isolation (customer keys never touch global env).
#   - LEAVE BLANK for legacy single-operator behaviour (env keys shared) — the
#     Connected tab still shows customers an honest red, but env stays shared.
HOUSE_WORKSPACE_ID=
# The CNAME target customers point their own domain at (shown in Setup -> Custom
# domain). Must resolve to this server: Caddy uses on-demand TLS (see Caddyfile)
# to issue a cert for the CNAMEd host once /api/caddyask confirms it's verified.
# recruitersos.co already has the A record + is served, so it's the safe target.
WHITE_LABEL_CNAME_TARGET=recruitersos.co

# --- Enrichment waterfall: RapidAPI listings (cheapest-first) ----------
# Each is its own RapidAPI subscription (billing is per-listing, not pooled).
# Leave blank to skip that rung; fill in the host + path template as you pick
# cheap listings. Path templates accept {first} {last} {name} {company} {domain}
# {linkedin} placeholders.
RAPIDAPI_KEY=
# Email finder (name + domain -> work email)
RAPIDAPI_EMAIL_HOST=
RAPIDAPI_EMAIL_PATH=
# Person / LinkedIn profile data
RAPIDAPI_PERSON_HOST=
RAPIDAPI_PERSON_PATH=
# PHONE: mobile and landline are SEPARATE rungs so you can point a better
# provider at each line type independently. (Optional cheap RapidAPI listings;
# deep research found none reliable, so gate them behind the Telnyx classify
# step below rather than trusting a scraper's own mobile/landline label.)
RAPIDAPI_MOBILE_HOST=
RAPIDAPI_MOBILE_PATH=
RAPIDAPI_LANDLINE_HOST=
RAPIDAPI_LANDLINE_PATH=
# (Legacy single-field phone rung, optional)
RAPIDAPI_PHONE_HOST=
RAPIDAPI_PHONE_PATH=

# --- Direct-dial finder: Apify (the person's own line, ~$0.10/found) ---
# ryanclinton "Phone Number Finder" actor. Runs as the backup landline rung
# (after the cheap RapidAPI rung) at the email-sent voice trigger; the found
# number is then classified by Telnyx before any voice drop.
APIFY_TOKEN=
# People Data Labs key — the actor's phone numbers come from PDL, so this is
# required for real direct dials. Free trial: 500 lookups / 30 days, no card
# (sign up at https://peopledatalabs.com/signup). Without it the actor only
# scrapes a company line off the website.
PDL_API_KEY=
# Override the actor id / mode if needed (one-line swap, no code change):
APIFY_DIRECT_DIAL_ACTOR=ryanclinton~phone-number-finder
APIFY_DIRECT_DIAL_MODE=balanced

# HARD per-contact USD cap on a DIAL (mobile/landline). Default $0.03. The
# waterfall skips any phone provider that would push a single contact's dial
# spend over this, so you NEVER pay more than this per person's number.
# IMPORTANT: at $0.03 the Apify direct-dial rung ($0.10/found) is ALWAYS skipped,
# so direct-dial fill rate will be low until a genuine <=$0.03 person-direct
# source is wired. Raise to 0.10 to unlock the Apify rung.
RECRUITEROS_MAX_DIAL_USD=0.03

# --- Phone enrichment: RECOMMENDED stack (verified May 2026) -----------
# FIND (the realistic reliable source for mobiles/direct dials):
#   Prospeo Mobile Finder ~$0.39/mobile. POST https://api.prospeo.io/mobile-finder
#   (header X-KEY), input = LinkedIn URL or name+company. Datagma/Apollo are alts.
PROSPEO_API_KEY=
# CLASSIFY mobile vs landline (cheap + reliable; reuses Telnyx above):
#   Telnyx Number Lookup, line-type ~$0.0025/query. Uses TELNYX_API_KEY.
#   GET https://api.telnyx.com/v2/number_lookup/{phone}?type=carrier
TELNYX_NUMBER_LOOKUP=1
# REVERSE lookup (number -> owner, optional): Trestle Reverse Phone ~$0.07/query
#   (on RapidAPI or direct at api.trestleiq.com). Leave blank to skip.
TRESTLE_API_KEY=
# Email verification (re-scores a found email)
EMAIL_VERIFY_HOST=
EMAIL_VERIFY_PATH=
# Cheapest credible email API (recommended primary)
ICYPEAS_API_KEY=
ICYPEAS_API_SECRET=

# ── In-Market paid NAMING fallback (RapidAPI people-search) ──
# Cheap fallback for the companies free research can't NAME. Called ONLY on a free miss (pay for
# misses only). Zero spend until RAPID_NAMING_KEY is set. Provider-agnostic: set HOST/PATH/METHOD/
# params to match whichever RapidAPI listing you subscribe to (defaults target Fresh LinkedIn
# Profile Data). The response parser is tolerant of both structured people arrays and SERP titles.
RAPID_NAMING_KEY=
RAPID_NAMING_HOST=fresh-linkedin-profile-data.p.rapidapi.com
RAPID_NAMING_PATH=/search-employees
RAPID_NAMING_METHOD=POST
RAPID_NAMING_QUERY_PARAM=keywords
RAPID_NAMING_COMPANY_PARAM=

# ── In-Market FREE naming booster: SearXNG meta-search ──
# Optional. Point this at a SearXNG instance (self-hosted is best — free, unlimited, no throttling)
# and the naming engine queries it FIRST: one call fans out across Google/Bing/etc server-side and
# returns clean JSON. Single biggest FREE lift to the naming rate. No-op until set.
#   e.g. INMARKET_SEARXNG_URL=https://searx.yourdomain.com
INMARKET_SEARXNG_URL=

# ── Seed-inbox warm-up: staff portal + safeguards ──
SENDING_SEED_PORTAL_TOKEN=        # random token; becomes the ?token= in the staff seed-portal link
SENDING_SECRET_KEY=               # AES key that encrypts stored seed app passwords (set before staff submit)
SENDING_WARMUP_ENGAGE=1           # turn the warm-up engagement loop on
SENDING_MAILBOXES_PER_DOMAIN=4    # one-click setup: warming mailboxes created per sending domain
