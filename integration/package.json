{
  "name": "recruiteros-backend",
  "version": "0.1.0",
  "private": true,
  "description": "RecruitersOS integration backend — LinkedIn engine, campaigns, prospects, response inbox, team auth.",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:fast": "node dev.cjs",
    "build": "next build",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit",
    "eval": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/eval-sourcing.mts",
    "shots": "tsx scripts/gen-shots.ts",
    "prebuild": "node sync-public.cjs",
    "sync": "node sync-public.cjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-sdk/client-s3": "^3.1075.0",
    "gifenc": "^1.0.3",
    "imapflow": "^1.3.7",
    "next": "14.2.5",
    "nodemailer": "^8.0.10",
    "pg": "^8.13.1",
    "playwright": "^1.61.0",
    "pngjs": "^7.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^29.1.1",
    "omggif": "^1.0.10",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4"
  }
}
