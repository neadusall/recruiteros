# Copy to .env.production on the server and fill in. Never commit the real file.

# Public URL (used in emails / magic links). Must match the var the app reads.
RECRUITEROS_APP_URL=https://recruitersos.co

# OS Text (taltxt) single sign-on. The portal signs logged-in users straight
# into OS Text via /api/ostext/enter, using taltxt's instant-access token. This
# MUST equal ACCESS_TOKEN in money-maker-sms/.env.production. deploy.sh wires it
# automatically; set by hand only for a manual deploy.
RECRUITEROS_OSTEXT_URL=https://taltxt.recruitersos.co
RECRUITEROS_OSTEXT_TOKEN=

# AI (personalization + reply classification)
ANTHROPIC_API_KEY=
RECRUITEROS_LLM_MODEL=claude-sonnet-4-6

# Outreach backend: leave blank to auto-detect (Unipile if its keys below are set,
# else our own in-backend bridge "self"). Force a choice: self | unipile | internal.
RECRUITEROS_OUTREACH_PROVIDER=
RECRUITEROS_OUTREACH_URL=
RECRUITEROS_OUTREACH_TOKEN=

# Unipile (hosted LinkedIn API) — set these three and LinkedIn automation (search,
# connect, message, InMail, profile view) runs server-side through Unipile.
# DSN + API key come from the Unipile dashboard ("Your new token" screen).
# ACCOUNT_ID is the connected LinkedIn seat: GET https://<DSN>/api/v1/accounts -> items[].id
UNIPILE_DSN=
UNIPILE_API_KEY=
UNIPILE_ACCOUNT_ID=
# Optional: HMAC secret to verify inbound Unipile webhooks (accept/reply events)
UNIPILE_WEBHOOK_SECRET=

# ── Sending infrastructure (owned cold-email stack: lib/sending) ──────────────
# Feed domains in the Sending tab; with these tokens set, DKIM + the full DNS
# record set (SPF/DKIM/DMARC/MX/tracking/return-path) + PTR are provisioned on
# Hetzner automatically. Without them the Sending tab still stores domains but
# provisioning stays dormant.
HCLOUD_TOKEN=            # Hetzner Cloud API (create MTA server + set PTR/rDNS)
HETZNER_DNS_TOKEN=       # Hetzner DNS API (create zones + write records)
SENDING_DMARC_RUA=       # optional, e.g. mailto:dmarc@yourdomain.com
SENDING_SERVER_TYPE=cx22 # Hetzner server type for the MTA box
SENDING_LOCATION=ash     # Hetzner location (ash=US East, nbg1=DE, etc.)
SENDING_IMAGE=ubuntu-24.04

# Texting: telnyx or internal
RECRUITEROS_SMS_PROVIDER=telnyx
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
# The 10DLC number we send SMS and place voice calls FROM (E.164, e.g. +13105551234).
TELNYX_FROM_NUMBER=

# Voice dialer + Premium AMD (answering-machine detection).
#   CONNECTION_ID       : Telnyx Call Control App / Voice connection to dial through.
#   TRANSFER_NUMBER     : rep line a live HUMAN is warm-transferred to (E.164).
#   VOICEMAIL_AUDIO_URL : public audio URL (wav/mp3) dropped when a MACHINE answers.
#                         Leave blank to just hang up on machines instead of a VM.
#   PUBLIC_KEY          : Telnyx ED25519 public key; when set, /api/voice/webhook
#                         verifies the event signature (blank = verification off).
TELNYX_CONNECTION_ID=
TELNYX_TRANSFER_NUMBER=
TELNYX_VOICEMAIL_AUDIO_URL=
TELNYX_PUBLIC_KEY=

# Voice Drops · cloned-voice provider (ElevenLabs-class TTS + instant voice clone).
# Powers the personalized voicemail drops; the cloned voice must be your OWN, captured
# with the recorded consent step. Unset = safe dry-run (nothing synthesized or dialed).
#   PROVIDER : adapter id (default "elevenlabs").
#   API_KEY  : provider api key.
#   VOICE_ID : default cloned voice id (the operator's consented voice).
#   CACHE_DIR: where rendered name/role/prose snippets are cached + reused for $0
#              (defaults to <cwd>/.data/voice-clones; put it on the persistent volume).
VOICE_CLONE_PROVIDER=elevenlabs
VOICE_CLONE_API_KEY=
VOICE_CLONE_VOICE_ID=
VOICE_CLONE_CACHE_DIR=
#
# Hiring-signal PiP role-video (PiP Studio) --------------------------------------------
# The audible "Hey {first name}," intro is spoken in the VOICE_CLONE_* voice above (set
# VOICE_CLONE_API_KEY + VOICE_CLONE_VOICE_ID to enable it; without them, videos still send
# with no spoken name). Optionally override just the intro voice:
RECRUITEROS_INTRO_VOICE_ID=
# Signed share-link lifetime in days for the watch page / email teaser (0 = never expire):
RECRUITEROS_SHARE_TTL_DAYS=45
# Turn the hands-off outreach cadence ON so the 2-email sequence actually SENDS (email 1 text
# now -> personalized video follow-up a few days later). off/unset = sequence armed but idle.
AUTOMATION_ENABLED=off
# (ffmpeg + Chromium for capture + compositing ship inside the Docker image — no keys needed.)
#
# Alternative cloned-voice vendors (same bring-your-own-voice contract — paste a
# voice id from the vendor and set VOICE_CLONE_PROVIDER to switch the default).
# Cartesia (Sonic TTS):
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
# Hume (Octave TTS): HUME_VOICE_SOURCE picks which pool a pasted id lives in —
# CUSTOM_VOICE (a voice you saved to your Hume account, default) or HUME_AI (a
# preset from Hume's shared Voice Library).
HUME_API_KEY=
HUME_VOICE_ID=
HUME_VOICE_SOURCE=CUSTOM_VOICE

# AI Vetting · inbound conversational screening (Telnyx AI Assistant + your cloned voice).
# Candidates opt in, then CALL a desk's number; an AI recruiter in your cloned voice screens
# them, and the call is recorded, transcribed, summarized, and scored 1-100. Reuses the
# Telnyx + ElevenLabs keys above; these only fine-tune it. Unset = safe dry-run (desks can be
# configured and the flow exercised, but no real calls are taken until TELNYX_API_KEY is set).
#   ENGINE_MODEL : the LLM the Telnyx assistant reasons with on-call (Telnyx-hosted id).
#   VETTING_MODEL: the model used for the post-call SCORING pass (defaults to the reasoning tier).
#   ELEVENLABS_KEY_REF: name of the ElevenLabs key stored in Telnyx (for the cloned voice).
# The dynamic-variables + post-call webhooks are derived from RECRUITEROS_APP_URL (top of file);
# Telnyx event signatures are verified by TELNYX_PUBLIC_KEY (above), shared with Voice Drops.
RECRUITEROS_VETTING_ENGINE_MODEL=
RECRUITEROS_VETTING_MODEL=
TELNYX_ELEVENLABS_KEY_REF=

# AI Vetting · TidyCal (scheduling feed). When set, the Bookings tab pulls upcoming
# TidyCal bookings, routes each to the desk whose role title matches the booking, and
# pre-researches the candidate's LinkedIn before their call. Add a phone + LinkedIn-URL
# question to your TidyCal booking type so we can match the inbound caller and prep the
# agent. Use a personal access token from tidycal.com/integrations/oauth (an MCP-scoped
# token may be rejected by the REST API). Unset = the Bookings tab shows "Connect TidyCal".
TIDYCAL_API_TOKEN=

# ATS (Loxo) — Candidates & Companies sync
# Credentials are entered PER-WORKSPACE in the portal (Admin → ATS → click Loxo):
# agency domain, agency slug, and API key. You do NOT need to set those here.
# LOXO_API_KEY below is only a legacy/global fallback for the original push-only
# adapter; leave it blank when using the in-portal setup.
LOXO_API_KEY=
#
# Public origin of THIS deployment, used to build the Loxo webhook callback URL
# when an admin clicks "Enable real-time". If unset we derive it from the request
# host (works behind the normal reverse proxy); set it explicitly if that's wrong.
APP_BASE_URL=
#
# Shared secret for scheduled syncs. Point a scheduler at:
#   GET https://<host>/api/loxo/cron   (header x-cron-secret: <this value>)
# every few minutes to incrementally re-pull anything changed in Loxo (also
# backfills any missed webhook). Reused by the other cron ticks.
RECRUITEROS_CRON_SECRET=
#
# Persistence for the synced data (Candidates warehouse + Companies book + ATS
# credentials). Set ONE of these or synced data is memory-only and resets on
# redeploy. ROS_DATA_DIR = a mounted volume path (zero-config default); or set
# DATABASE_URL for Postgres.
ROS_DATA_DIR=

# Session signing secret (generate a long random string)
RECRUITEROS_SESSION_SECRET=

# Email sending (password resets, magic links, verification).
# Without RESEND_API_KEY, emails are only logged, NOT sent. Get a free key at
# resend.com, verify your domain, then set both:
RESEND_API_KEY=
EMAIL_FROM=RecruitersOS <no-reply@recruitersos.co>

# Cold email (outbound campaigns) — see docs/setup/channels/cold-email.md for the full walk.
# Instantly.ai is the sending channel: the daily cadence pushes approved drafts
# into your Instantly campaign, which sends from your own warmed inboxes and
# runs the drip + opens/clicks/replies. Without INSTANTLY_API_KEY, email sends
# are logged only, NOT sent (same dry-run behavior as RESEND above).
INSTANTLY_API_KEY=
# Authenticates Instantly's reply webhook -> /api/response/webhook/instantly?ws=<workspaceId>
INSTANTLY_WEBHOOK_SECRET=
# Email-finding waterfall (resolves a work email before the email step fires).
# Cheapest-first: a RapidAPI listing, then Icypeas. Leave blank to skip a rung;
# with none set, only prospects that already have an email get emailed.
RAPIDAPI_KEY=
RAPIDAPI_EMAIL_HOST=
RAPIDAPI_EMAIL_PATH=
ICYPEAS_API_KEY=
ICYPEAS_API_SECRET=
# Email verification (re-scores a found email before it touches a warmed inbox).
EMAIL_VERIFY_HOST=
EMAIL_VERIFY_PATH=

# ---------------------------------------------------------------------------
# Paid JOB FEED — the breadth lever past the free pool (Hire Signals inflow).
# Provider we standardized on: JSearch by OpenWeb Ninja (Google for Jobs).
#   Subscribe: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Dormant (zero spend) until KEY + HOST are set. Easiest: run set-rapidjobs.sh.
# Each lead's posting link → lead.sourceUrl, which feeds the roleShot screen-
# capture (the picture-in-picture video-email background).
RAPID_JOBS_KEY=
RAPID_JOBS_HOST=jsearch.p.rapidapi.com
RAPID_JOBS_PROVIDER=jsearch
RAPID_JOBS_DATE=week
# Volume pacing — tune to your plan's monthly request quota. JSearch bills each
# num_pages page as a request, and num_pages = RAPID_JOBS_PAGE / 10.
# Inflow ≈ RAPID_JOBS_PAGE × RAPID_JOBS_PAGES_PER_CYCLE × 24 cycles/day × 30.
#   ULTRA ($75 / 50K req-mo → ~500K jobs/mo):  PAGE=50  PAGES_PER_CYCLE=14
#   PRO   ($25 / 10K req-mo → ~100K jobs/mo):  PAGE=50  PAGES_PER_CYCLE=3
#   MEGA  ($150 / 200K req-mo → ~2M jobs/mo):  PAGE=50  PAGES_PER_CYCLE=55
RAPID_JOBS_PAGE=50
RAPID_JOBS_PAGES_PER_CYCLE=14

# Decision-maker naming — Real-Time Web Search (RapidAPI). This is the search backend that finds
# the hiring manager / economic buyer for each role. A Google-backed SERP API, so it honors
# `site:linkedin.com/in` X-ray queries and returns clean JSON. When RAPID_WEBSEARCH_KEY is set it
# REPLACES the free search-engine scrapers (DuckDuckGo/Bing/Mojeek/SearXNG) as the sole search
# source — no per-IP throttle — so naming is JSearch + real-time-web-search only. Leave the key
# blank to fall back to the free scrapers (local/dev).
#   https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-web-search
RAPID_WEBSEARCH_KEY=
RAPID_WEBSEARCH_HOST=real-time-web-search.p.rapidapi.com
RAPID_WEBSEARCH_PATH=/search
RAPID_WEBSEARCH_QUERY_PARAM=q
RAPID_WEBSEARCH_LIMIT=20
RAPID_WEBSEARCH_GL=us
RAPID_WEBSEARCH_HL=en

# Direct-dial finder (the person's own line, ~$0.10/found). The ryanclinton
# "Phone Number Finder" Apify actor (phone data from People Data Labs), looked up
# lazily at the email-sent voice trigger and confirmed by Telnyx before any drop.
# PDL_API_KEY is required for real numbers (free trial: 500 lookups / 30 days).
APIFY_TOKEN=
PDL_API_KEY=
APIFY_DIRECT_DIAL_ACTOR=ryanclinton~phone-number-finder
APIFY_DIRECT_DIAL_MODE=balanced

# LinkedIn scraper sidecar (the open-source Playwright engine, an ALTERNATIVE to
# Unipile for the "Pull LinkedIn profiles" flow). The `scraper` compose service
# drives a real logged-in browser. Auth is a single session cookie:
#   LINKEDIN_LI_AT : the `li_at` cookie from a logged-in linkedin.com browser
#                    (DevTools -> Application -> Cookies -> li_at). Leave blank to
#                    disable the scraper engine; the UI keeps the Unipile option.
#   SCRAPER_TOKEN  : shared secret the app sends on every scrape call (set any long
#                    random string; both the app and scraper read it from here).
#   SCRAPER_URL    : internal URL of the sidecar (default below; rarely changed).
# ⚠️ Scraping risks the account behind this cookie — use a dedicated one.
LINKEDIN_LI_AT=
SCRAPER_TOKEN=
SCRAPER_URL=http://scraper:8000

# "Sign in with LinkedIn" (OpenID Connect). Create a free app at
# linkedin.com/developers, add the "Sign In with LinkedIn using OpenID Connect"
# product, set the redirect URL to https://recruitersos.co/api/auth/linkedin/callback
# Then paste the app's Client ID + Secret here. If unset, the button shows a
# friendly "not set up yet" message.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Hire Signals · validation + background asset generation ───────────────────
# Reoon email validation (already wired in lib/inmarket/reoon.ts). Set the key to confirm mailboxes
# (works despite Hetzner's port-25 block — Reoon does the SMTP from its own infra).
REOON_API_KEY=
REOON_ACCEPT_CATCHALL=1                   # treat catch-all corporate domains as valid (0 = strict)
# Make the WHOLE funnel validated-only (only Reoon-confirmed emails enroll into BD Bulk).
INMARKET_REQUIRE_VALIDATED=
#
# Background CAPTURE generator — auto screen-captures each contact's job posting so the whole book
# becomes video-ready hands-off (was on-demand only, which is why "with video" was tiny). CPU-heavy,
# so it ships OFF and runs a small batch at a time. Raise the batch on a bigger box / worker. Track
# progress via the engine_health API (autoCapture.totalMade).
INMARKET_AUTOCAPTURE=
INMARKET_AUTOCAPTURE_BATCH=6              # captures attempted per tick (1..500)
INMARKET_AUTOCAPTURE_CONCURRENCY=1        # captures run AT ONCE (1..8) — the throughput lever; raise toward vCPU count
INMARKET_AUTOCAPTURE_INTERVAL_SEC=180    # how often the tick runs
INMARKET_AUTOCAPTURE_MIN_SCORE=0         # only capture rows scoring >= this (prioritize hot leads)
# Throughput note: one box does ~2-3K heavy captures/day flat out. For 5K+/day, raise CONCURRENCY
# toward the box's vCPU count AND spread the work across the worker fleet (each box adds its own).
#
# Background VIDEO compositor — overlays your ONE recorded clip on each capture into a send-ready
# outreach video, hands-off, every video a fixed length (42s). Record one clip in Video Studio
# first; it defaults to the latest clip in the workspace (or pin INMARKET_AUTOVIDEO_CLIP_ID). CPU-heavy
# (each = an ffmpeg composite on top of the capture) — off by default. Progress: engine_health.autoVideo.
INMARKET_AUTOVIDEO=
INMARKET_AUTOVIDEO_WORKSPACE=            # whose clip to use (defaults to INMARKET_AUTOENROLL_WORKSPACE)
INMARKET_AUTOVIDEO_CLIP_ID=             # the clip to overlay (defaults to the latest clip in that workspace)
INMARKET_AUTOVIDEO_SECONDS=42           # length of every video (5..180)
INMARKET_AUTOVIDEO_BATCH=6              # videos attempted per tick
INMARKET_AUTOVIDEO_CONCURRENCY=1        # composites run at once (1..6) — the throughput lever
INMARKET_AUTOVIDEO_INTERVAL_SEC=180     # how often the tick runs

# Owner Console (private back office). ONLY these emails can reach /api/owner/*;
# everyone else gets a 404. Comma-separate for more than one. REQUIRED in
# production, or the console falls back to the build owner.
OWNER_EMAIL=neadusall@gmail.com
# Private URL slug: the console is served ONLY at /<slug>.html (no guessable
# /owner-console path exists). Blank = a stable random slug is generated into
# integration/.owner-console-slug at build and printed in the build log. Set to
# pin/rotate your own. Treat it like a password.
OWNER_CONSOLE_SLUG=
# Optional Bearer key for background workers to report cost to the ledger.
USAGE_INGEST_KEY=

# Database (Postgres). The compose `db` service and the app BOTH read this file,
# so POSTGRES_PASSWORD is the single source of truth — set it once here. The app
# derives its connection from it automatically, so DATABASE_URL is optional; if
# you do set DATABASE_URL, give it the SAME password.
POSTGRES_PASSWORD=
# DATABASE_URL=postgres://recruiteros:SAME_AS_POSTGRES_PASSWORD@db:5432/recruiteros
